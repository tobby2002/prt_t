//@version=6
indicator("Adaptive & Standard RSI Combined [AdapStan]", overlay=false, max_lines_count = 500, max_polylines_count = 100, precision = 1)

// --- Visibility Toggles ---
showAdaptive = input.bool(true, "Show Adaptive RSI", group="Visibility Settings")
showStandard = input.bool(true, "Show Standard RSI", group="Visibility Settings")

// --- Adaptive RSI Settings ---
rsiLength           = input.int(14, minval=1, title="RSI Length", group="Adaptive RSI (Gaussian Weighted)")
sigma               = input.float(3.0, minval=0.01, title="Gaussian Sigma", group="Adaptive RSI (Gaussian Weighted)")
enableMA            = input.bool(true, title="Signal Line", group="Signal Line")
signallength        = input.int(9, minval=1, title="Signal Length", group="Signal Line")
calculateDivergence = input.bool(false, title="Real-Time Divergence", group="Real-Time Divergence")
lookbackLeft        = input.int(20, minval=1, title="Lookback", group="Real-Time Divergence")
bearColor           = input.color(color.red,   "Bearish Color", group="Real-Time Divergence")
bullColor           = input.color(color.green, "Bullish Color", group="Real-Time Divergence")
textColor           = input.color(color.white, "Text Color", group="Real-Time Divergence")
noneColor           = color.new(color.white, 100)

// --- Standard RSI Settings ---
rsiLengthInput = input.int(14, minval=1, title="RSI Length", group="RSI Settings")
rsiSourceInput = input.source(close, "Source", group="RSI Settings")
calculateDivergenceReg = input.bool(false, title="Calculate Divergence", group="RSI Settings", display = display.none, tooltip = "Calculating divergences is needed in order for divergence alerts to fire.")

// Standard RSI Smoothing MA inputs
GRP = "Standard RSI Smoothing"
TT_BB = "Only applies when 'SMA + Bollinger Bands' is selected. Determines the distance between the SMA and the bands."
maTypeInput = input.string("SMA", "Type", options = ["None", "SMA", "SMA + Bollinger Bands", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group = GRP, display = display.none)
var isBB = maTypeInput == "SMA + Bollinger Bands"
maLengthInput = input.int(14, "Length", group = GRP, display = display.none, active = maTypeInput != "None")
bbMultInput = input.float(2.0, "BB StdDev", minval = 0.001, maxval = 50, step = 0.5, tooltip = TT_BB, group = GRP, display = display.none, active = isBB)
var enableMAReg = maTypeInput != "None"


// ==========================================
// 1. ADAPTIVE RSI CALCULATION & PLOTS
// ==========================================

float weightedGain = 0.0
float weightedLoss = 0.0
float totalWeight = 0.0

for i = 1 to rsiLength
    weight = math.exp(-math.pow(i - (rsiLength/2), 2) / (2 * math.pow(sigma, 2)))
    totalWeight += weight
    delta = close[i - 1] - close[i]  
    gain = delta > 0 ? delta : 0.0
    loss = delta < 0 ? -delta : 0.0
    weightedGain += gain * weight
    weightedLoss += loss * weight

avgGain = weightedGain / totalWeight
avgLoss = weightedLoss / totalWeight

rs = avgLoss == 0 ? 0 : avgGain / avgLoss
rsiAdaptive  = avgLoss == 0 ? 100 : 100 - (100 / (1 + rs))
smoothingRSI = ta.sma(rsiAdaptive, signallength)

// Only plot/fill if showAdaptive is enabled
rsiPlot = plot(showAdaptive ? rsiAdaptive : na, "Adaptive RSI", color=color.blue)
plot(showAdaptive and enableMA ? smoothingRSI : na, "Adaptive RSI-based MA", color=color.yellow)
rsiUpperBand = hline(70, "Adaptive Overbought", color=showAdaptive ? color.red : color.new(color.red, 100))
rsiLowerBand = hline(30, "Adaptive Oversold", color=showAdaptive ? color.green : color.new(color.green, 100))
midLinePlot = plot(showAdaptive ? 50 : na, color = chart.fg_color, display=display.none)

fill(rsiUpperBand, rsiLowerBand, color=showAdaptive ? color.rgb(126, 87, 194, 90) : na, title="Adaptive RSI Background Fill")
fill(rsiPlot, midLinePlot, 100, 60, top_color = showAdaptive ? color.new(color.green, 0) : na, bottom_color = showAdaptive ? color.new(color.green, 100) : na,  title = "Adaptive Overbought Gradient Fill")
fill(rsiPlot, midLinePlot, 40,  0,  top_color = showAdaptive ? color.new(color.red, 100) : na, bottom_color = showAdaptive ? color.new(color.red, 0) : na,      title = "Adaptive Oversold Gradient Fill")

p1 = plot(showAdaptive ? rsiAdaptive : na, color = color.blue, display = display.none, editable = false)
p2 = plot(showAdaptive ? rsiAdaptive[4] : na, display = display.none, editable = false)
fill(p1, p2, showAdaptive ? rsiAdaptive : na, showAdaptive ? rsiAdaptive[4] : na, color.blue, na)

// Divergence for Adaptive RSI
var bool plFound = false
var bool phFound = false
var bool bullCond = false
var bool bearCond = false

if showAdaptive and calculateDivergence
    plFound := not na(ta.pivotlow(rsiAdaptive, lookbackLeft, 0))
    rsiHL = rsiAdaptive > ta.valuewhen(plFound, rsiAdaptive, 1) 
    priceLL = low < ta.valuewhen(plFound, low, 1)
    bullCond := priceLL and rsiHL and plFound
    phFound := not na(ta.pivothigh(rsiAdaptive, lookbackLeft, 0))
    rsiLH = rsiAdaptive < ta.valuewhen(phFound, rsiAdaptive, 1)
    priceHH = high > ta.valuewhen(phFound, high, 1)
    bearCond := priceHH and rsiLH and phFound

plot(showAdaptive and plFound ? rsiAdaptive : na, title="Adaptive Bullish Pivot", linewidth=2, color=(bullCond ? bullColor : noneColor))
plotshape(showAdaptive and bullCond ? rsiAdaptive : na, title="Adaptive Bullish Divergence Label", text=" Bull ", style=shape.labelup, location=location.absolute, color=bullColor, textcolor=textColor)
plot(showAdaptive and phFound ? rsiAdaptive : na, title="Adaptive Bearish Pivot", linewidth=2, color=(bearCond ? bearColor : noneColor))
plotshape(showAdaptive and bearCond ? rsiAdaptive : na, title="Adaptive Bearish Divergence Label", text=" Bear ", style=shape.labeldown, location=location.absolute, color=bearColor, textcolor=textColor)

alertcondition(bullCond, title="Adaptive Real-time Bullish Divergence", message="New Real-time Bullish Divergence detected (Adaptive).")
alertcondition(bearCond, title="Adaptive Real-time Bearish Divergence", message="New Real-time Bearish Divergence detected (Adaptive).")

// Trailing Stop (from Adaptive RSI)
sig   = input.bool(true, title="Crosses Signals", group="Bullish/Bearish Signals", inline="")
butri = input.int(20, minval=1, maxval=99, title="Trigger Bull when ta.crossover(rsi,value)", group="Bullish/Bearish Signals", inline="")
betri = input.int(80, minval=1, maxval=99, title="Trigger Bear when ta.crossunder(rsi,value)", group="Bullish/Bearish Signals", inline="")

trEn = input.bool(true, title='Crosses Trailing Stop', group="Trailing Stop", tooltip='Enable or disable the breakout trailing stop feature. When enabled, trailing stops are calculated based on ATR.')
m = input.float(3, minval=0.1, step=0.1, title='Trailing Multiplier', group="Trailing Stop", tooltip='ATR multiplier for calculating the trailing stop. Higher values result in wider stops, reducing the chance of premature exit.')
lw = input.int(1, minval=1, title='Trailing Line Width', group="Trailing Stop", tooltip='Width of the trailing stop line displayed on the chart.')
posClr = input.color(color.rgb(119, 255, 0), title='', group='Trailing Stop', inline='Style')
negClr = input.color(color.rgb(255, 0, 13), title='', group='Trailing Stop', inline='Style')
atr = ta.atr(100)

// Functions for Trailing Stop Updates 
f_updateBull(bullTrig, bullAct, preStop, ts, pts, cross, col, lw) =>
    var float newTS = ts
    var bool newActive = bullAct
    var bool actPlot = false
    if bullTrig or bullAct
        if bullTrig
            array.unshift(pts, chart.point.from_index(bar_index, preStop))
            newTS := preStop
            newActive := true
        else
            array.unshift(pts, chart.point.from_index(bar_index, math.max(preStop, newTS)))
            newTS := math.max(preStop, newTS)
            actPlot := true
        if cross
            newActive := false
            newTS := float(na)
            polyline.new(pts, line_color = col, line_width = lw, force_overlay = true)
            array.clear(pts)
    [newTS, newActive, actPlot]

f_updateBear(bearTrig, bearAct, preStop, ts, pts, cross, col, lw) =>
    var float newTS = ts
    var bool newActive = bearAct
    var bool actPlot = false
    if bearTrig or bearAct
        if bearTrig
            array.unshift(pts, chart.point.from_index(bar_index, preStop))
            newTS := preStop
            newActive := true
        else
            array.unshift(pts, chart.point.from_index(bar_index, math.min(preStop, newTS)))
            newTS := math.min(preStop, newTS)
            actPlot := true
        if cross
            newActive := false
            newTS := float(na)
            polyline.new(pts, line_color = col, line_width = lw, force_overlay = true)
            array.clear(pts)
    [newTS, newActive, actPlot]

var ptsBull = array.new<chart.point>()    
var ptsBear = array.new<chart.point>()    
var polyline pBull = na                   
var polyline pBear = na                   
var bullPos = false                       
var bearPos = false                      
var tsBull = float(na)                    
var tsBear = float(na)                    

bool bullAct = false
bool bearAct = false                    

color bLblClr = color.new(color.green, 0) 
color rLblClr = color.new(color.red, 0)   
lblSz = size.normal                     

bool isB = ta.crossover(rsiAdaptive, butri)  
bool isBr = ta.crossunder(rsiAdaptive, betri) 

float preBullStop = low - atr * m      
float preBearStop = high + atr * m          

bool crossBull = ta.crossunder(low, tsBull) 
bool crossBear = ta.crossover(high, tsBear)  

bool bullT = isB and not isB[1] and trEn and showAdaptive    
bool bearT = isBr and not isBr[1] and trEn and showAdaptive   

[newTSBull, newBullPos, newBullAct] = f_updateBull(bullT, bullPos, preBullStop, tsBull, ptsBull, crossBull, posClr, lw)
tsBull := newTSBull      
bullPos := newBullPos     
bullAct := newBullAct     
pBull.delete()          
if showAdaptive and ptsBull.size() > 0
    pBull := polyline.new(ptsBull, false, false, line_color = posClr, line_width = lw, force_overlay = true)

[newTSBear, newBearPos, newBearAct] = f_updateBear(bearT, bearPos, preBearStop, tsBear, ptsBear, crossBear, negClr, lw)
tsBear := newTSBear       
bearPos := newBearPos    
bearAct := newBearAct     
pBear.delete()           
if showAdaptive and ptsBear.size() > 0
    pBear := polyline.new(ptsBear, false, false, line_color = negClr, line_width = lw, force_overlay = true)

plotshape(showAdaptive and bullT and sig ? low - atr * m : na, location = location.absolute, style = shape.circle, color = posClr, size = size.tiny, title = 'Bullish Trailing Starts', force_overlay = true)
plotshape(showAdaptive and bullT and newBullPos[1] == false  and sig? low - atr * m : na, location = location.absolute, style = shape.circle, color = color.new(posClr, 50), size = size.small, title = 'Bullish Trailing Starts', force_overlay = true)
plotshape(showAdaptive and bearT and sig? high + atr * m : na, location = location.absolute, style = shape.circle, color = negClr, size = size.tiny, title = 'Bearish Trailing Starts', force_overlay = true)
plotshape(showAdaptive and bearT and newBearPos[1] == false and sig? high + atr * m : na, location = location.absolute, style = shape.circle, color = color.new(negClr, 50), size = size.small, title = 'Bearish Trailing Starts', force_overlay = true)

plotshape(showAdaptive and bullT and sig? rsiAdaptive : na, location = location.absolute, style = shape.circle, color = posClr, size = size.tiny, title = 'Bullish Trailing Starts')
plotshape(showAdaptive and bullT and newBullPos[1] == false and sig? rsiAdaptive : na, location = location.absolute, style = shape.circle, color = color.new(posClr, 50), size = size.small, title = 'Bullish Trailing Starts')
plotshape(showAdaptive and bearT and sig? rsiAdaptive : na, location = location.absolute, style = shape.circle, color = negClr, size = size.tiny, title = 'Bearish Trailing Starts')
plotshape(showAdaptive and bearT and newBearPos[1] == false and sig? rsiAdaptive : na, location = location.absolute, style = shape.circle, color = color.new(negClr, 50), size = size.small, title = 'Bearish Trailing Starts')


// ==========================================
// 2. STANDARD RSI CALCULATION & PLOTS
// ==========================================

change = ta.change(rsiSourceInput)
up = ta.rma(math.max(change, 0), rsiLengthInput)
down = ta.rma(-math.min(change, 0), rsiLengthInput)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - (100 / (1 + up / down))

// Plot Standard RSI as white default (option-controlled)
plot(showStandard ? rsi : na, "Standard RSI", color=color.white)

// hline cannot be dynamic, but we can plot lines at 70, 50, 30 if showStandard is true
plot(showStandard ? 70 : na, "Standard RSI Upper Band", color=#787B86, display=display.all)
plot(showStandard ? 50 : na, "Standard RSI Middle Band", color=color.new(#787B86, 50), display=display.all)
plot(showStandard ? 30 : na, "Standard RSI Lower Band", color=#787B86, display=display.all)

// Smoothing MA Calculation function
ma(source, length, MAtype) =>
    switch MAtype
        "SMA"                   => ta.sma(source, length)
        "SMA + Bollinger Bands" => ta.sma(source, length)
        "EMA"                   => ta.ema(source, length)
        "SMMA (RMA)"            => ta.rma(source, length)
        "WMA"                   => ta.wma(source, length)
        "VWMA"                  => ta.vwma(source, length)

// Smoothing MA plots (no fills for Standard RSI, default color is yellow)
smoothingMA = showStandard and enableMAReg ? ma(rsi, maLengthInput, maTypeInput) : na
smoothingStDev = showStandard and isBB ? ta.stdev(rsi, maLengthInput) * bbMultInput : na
plot(smoothingMA, "Standard RSI-based MA", color=color.blue)
plot(showStandard and isBB ? smoothingMA + smoothingStDev : na, title = "Standard Upper Bollinger Band", color=color.green)
plot(showStandard and isBB ? smoothingMA - smoothingStDev : na, title = "Standard Lower Bollinger Band", color=color.green)

// Divergence for Standard RSI
lookbackRightReg = 5
lookbackLeftReg = 5
rangeUpper = 60
rangeLower = 5
bearColorReg = color.red
bullColorReg = color.green
textColorReg = color.white
noneColorReg = color.new(color.white, 100)

_inRange(bool cond) =>
    bars = ta.barssince(cond)
    rangeLower <= bars and bars <= rangeUpper

plFoundReg = false
phFoundReg = false
bullCondReg = false
bearCondReg = false

rsiLBR = rsi[lookbackRightReg]

if showStandard and calculateDivergenceReg
    plFoundReg := not na(ta.pivotlow(rsi, lookbackLeftReg, lookbackRightReg))    
    rsiHL = rsiLBR > ta.valuewhen(plFoundReg, rsiLBR, 1) and _inRange(plFoundReg[1])
    lowLBR = low[lookbackRightReg]
    priceLL = lowLBR < ta.valuewhen(plFoundReg, lowLBR, 1)
    bullCondReg := priceLL and rsiHL and plFoundReg

    phFoundReg := not na(ta.pivothigh(rsi, lookbackLeftReg, lookbackRightReg))
    rsiLH = rsiLBR < ta.valuewhen(phFoundReg, rsiLBR, 1) and _inRange(phFoundReg[1])
    highLBR = high[lookbackRightReg]
    priceHH = highLBR > ta.valuewhen(phFoundReg, highLBR, 1)
    bearCondReg := priceHH and rsiLH and phFoundReg

plot(
     showStandard and plFoundReg ? rsiLBR : na,
     offset    = -lookbackRightReg,
     title     = "Standard Regular Bullish",
     linewidth = 2,
     color     = (bullCondReg ? bullColorReg : noneColorReg),
     display   = display.pane,
     editable  = calculateDivergenceReg)

plotshape(
     showStandard and bullCondReg ? rsiLBR : na,
     offset    = -lookbackRightReg,
     title     = "Standard Regular Bullish Label",
     text      = " Bull ",
     style     = shape.labelup,
     location  = location.absolute,
     color     = bullColorReg,
     textcolor = textColorReg,
     display   = display.pane,
     editable  = calculateDivergenceReg)

plot(
     showStandard and phFoundReg ? rsiLBR : na,
     offset    = -lookbackRightReg,
     title     = "Standard Regular Bearish",
     linewidth = 2,
     color     = (bearCondReg ? bearColorReg : noneColorReg),
     display   = display.pane,
     editable  = calculateDivergenceReg)

plotshape(
     showStandard and bearCondReg ? rsiLBR : na,
     offset    = -lookbackRightReg,
     title="Standard Regular Bearish Label",
     text      = " Bear ",
     style     = shape.labeldown,
     location  = location.absolute,
     color     = bearColorReg,
     textcolor = textColorReg,
     display   = display.pane,
     editable  = calculateDivergenceReg)

alertcondition(bullCondReg, title='Standard Regular Bullish Divergence', message="Found a new Regular Bullish Divergence (Standard).")
alertcondition(bearCondReg, title='Standard Regular Bearish Divergence', message='Found a new Regular Bearish Divergence (Standard).')
